# ./.gitignore
# Switch SD Manager - Public Repository Gitignore
# Hardened for public GitHub: blocks keys, credentials, build artifacts, and personal data.

# ===========================
# Node & Build Output
# ===========================
node_modules/
dist/
dist-ssr/
*.local

# ===========================
# Logs
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===========================
# Editor & OS Files
# ===========================
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===========================
# Rust / Cargo Compiler Output
# ===========================
/src-tauri/target/
/src-tauri/gen/
target/

# ===========================
# PRIVATE: Nintendo Switch Keys & Credentials
# These MUST NEVER be committed to a public repo.
# ===========================
*.keys
*.key
key_retail.bin
keys.txt
credentials.json
gdrive.token
*.pem
*.p12
*.pfx

# ===========================
# PRIVATE: Build & Custom Content Directories
# Personal build output, themes, payloads, and configs.
# ===========================
/build/
/build_portable/
/Reference/
/RCMLoader/
/Custom_stuff/
/SD/

# ===========================
# PRIVATE: Reference Scripts (from other projects)
# ===========================
/reference_Scripts_from_other_project/

# ===========================
# PRIVATE: Local Config & User Settings
# ===========================
/configs/config.json
/configs/sources.json
/configs/manifest.lock
/configs/custom_manifest.lock
/configs/nro_cache.json
/configs/cache/
switch-sd-updater_settings.json
portable_settings.json
/data/

# ===========================
# Development Scratch Files
# Refactoring backups, temp files, etc.
# ===========================
*.tmp
*.bak
*.temp_*
*.original
*.original_rebuilt
*.reconstructed
*.restored_from_conv
*.restored_full
*.restored_part
*.extracted_row_*.txt

# ===========================
# Agent / Session Memory (Private)
# ===========================
MEMORY.md

# ===========================
# Environment & Secrets
# ===========================
.env
.env.*
!.env.example
